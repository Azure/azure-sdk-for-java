<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="manual-thinclient-network-delay" parallel="false" thread-count="1">
  <listeners>
    <listener class-name="com.azure.cosmos.CosmosNettyLeakDetectorFactory"/>
  </listeners>
  <test name="manual-thinclient-network-delay" group-by-instances="true">
    <groups>
      <run>
        <include name="manual-thinclient-network-delay"/>
      </run>
    </groups>
    <packages>
      <package name="com.azure.cosmos.*"/>
    </packages>
  </test>
</suite>
